                            id:
                              type: number
                            name:
                              type: string
                          required:
                            - id
                            - name
                          additionalProperties: false
                        description: Page of items
                      nextCursor:
                        type:
                          - string
                          - "null"
                      hasMore:
                        description: Whether more pages exist
                        type: boolean
                      limit:
                        type: integer
                        minimum: 1
                        maximum: 9007199254740991
                        description: Page size used
                    required:
                      - items
