                      - message
                    additionalProperties: false
                required:
                  - status
                  - error
                additionalProperties: false
              examples:
                example1:
                  value:
                    status: error
                    error:
                      message: Sample error message
    head:
      operationId: HeadPosts
      parameters:
        - name: cursor
          in: query
          required: false
          description: Cursor for the next page; omit for first page
          schema:
            description: Cursor for the next page; omit for first page
            type: string
        - name: limit
          in: query
          required: false
          description: Page size (number of items per page)
          schema:
            default: 20
