{
  "private": true,
  "type": "module",
  "scripts": {
    "start": "pnpm -F example start",
    "prebuild": "tsx tools/contributors.ts && tsx tools/license.ts",
    "build": "pnpm -r build",
    "pretest": "tsx tools/make-tests.ts",
    "test": "pnpm -r test",
    "bench": "pnpm -F express-zod-api bench",
    "lint": "eslint && prettier *.md **/*.md --check",
    "mdfix": "prettier *.md **/*.md --write",
    "precommit": "pnpm lint && pnpm build && pnpm test && git add *.md example/example.* LICENSE",
    "install_hooks": "husky"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@tsconfig/node20": "^20.1.8",
    "@types/node": "^24.10.9",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-allowed-dependencies": "^2.0.1",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "prettier": "3.8.1",
    "tsdown": "^0.21.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "catalog:dev",
    "vitest": "^4.0.16"
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
