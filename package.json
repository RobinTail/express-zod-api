{
  "private": true,
  "type": "module",
  "scripts": {
    "start": "pnpm -F example start",
    "prebuild": "unrun tools/contributors.ts && unrun tools/license.ts",
    "build": "pnpm -r build",
    "pretest": "unrun tools/make-tests.ts",
    "test": "pnpm -r test",
    "bench": "pnpm -F express-zod-api bench",
    "lint": "eslint && prettier *.md **/*.md --check",
    "mdfix": "prettier *.md **/*.md --write",
    "precommit": "pnpm lint && pnpm build && pnpm test && git add *.md example/example.* LICENSE",
    "install_hooks": "husky"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.2",
    "@tsconfig/node20": "^20.1.8",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-allowed-dependencies": "^2.2.0",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "prettier": "3.8.3",
    "tsdown": "^0.21.10",
    "typescript-eslint": "catalog:dev",
    "unrun": "^0.2.37",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@11.0.5+sha512.94fa09e72016402aefce788e46994e18eb1922998b16b6fd5aa6bafd8ae4dea05d0852f60247fdb7d5ab8199a7b0beda830398f3f80cb9f822398522a1535481"
}
